# ─────────────────────────────────────────────────────────────
#  FICHIER MODÈLE — copie ce fichier en ".env" et remplis les clés
#  IMPORTANT : Ne partage JAMAIS le fichier .env avec qui que ce soit !
# ─────────────────────────────────────────────────────────────

# Clé API Anthropic (pour l'IA Claude)
# → Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REMPLACE_PAR_TA_CLE

# Clés API Binance (pour lire le prix BTC — pas d'ordre réel)
# → Obtenir sur : https://www.binance.com/fr/my/settings/api-management
# → Crée une clé avec uniquement "Enable Reading" coché (pas de trading réel !)
BINANCE_API_KEY=REMPLACE_PAR_TA_CLE_BINANCE
BINANCE_SECRET=REMPLACE_PAR_TON_SECRET_BINANCE

# Clé API NewsData.io (pour les actualités crypto)
# → Obtenir gratuitement sur : https://newsdata.io/ (crée un compte, plan gratuit suffisant)
NEWSDATA_API_KEY=pub_REMPLACE_PAR_TA_CLE
